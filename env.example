# ─────────────────────────────────────────────
# Newsia — Environment Variables
# Copy this file to .env.local and fill in your keys
# Never commit .env.local to git
# ─────────────────────────────────────────────

# Supabase — get from supabase.com > your project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Google Gemini — get from aistudio.google.com > Get API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (fallback AI) — get from console.groq.com > API Keys
GROQ_API_KEY=your_groq_api_key_here

# NewsAPI — get from newsapi.org > Get API Key (free tier)
NEWS_API_KEY=your_newsapi_key_here

# GNews — get from gnews.io (free tier)
GNEWS_API_KEY=your_gnews_api_key_here

# App URL — use localhost for development, your Vercel URL for production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret — any random string, used to secure the pipeline endpoint in production
CRON_SECRET=make_this_something_random_and_long
